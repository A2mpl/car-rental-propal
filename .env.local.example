# ══════════════════════════════════════════════════════════════════════════════
# car-rental-propal — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Identité du site ──────────────────────────────────────────────────────────
#
# Nom de marque affiché dans les titres, metadata, JSON-LD et contenus.
# Changer cette valeur met à jour l'ensemble du site sans toucher au code.
# Valeur par défaut (si absent) : 'Timeless'
#
NEXT_PUBLIC_SITE_NAME=Timeless

# URL de production sans slash final (utilisée pour SEO : sitemap, OG, canonical).
#
NEXT_PUBLIC_SITE_URL=https://timeless-cars.fr

# ── AutoScout24 Dealer API (OAuth 2.0 Client Credentials) ─────────────────────
#
# Get your credentials at: https://developer.autoscout24.com
# Once set, the app automatically uses the real AS24 API instead of mock data.
#
AS24_CLIENT_ID=your_client_id_here
AS24_CLIENT_SECRET=your_client_secret_here

# Market / locale — ISO 3166-1 alpha-2 country code (default: FR)
# Affects which listings are returned and in which currency.
# Supported: DE | FR | IT | ES | BE | NL | AT | CH | PL | ...
AS24_MARKET=FR

# Optional: override API base URL (useful for staging / mock servers)
# AS24_API_BASE=https://api.autoscout24.com

# Optional: override token endpoint (advanced — rarely needed)
# AS24_TOKEN_URL=https://accounts.autoscout24.com/connect/token

# ── Contact form — destinataire des messages ──────────────────────────────────
#
# Email qui reçoit les soumissions du formulaire de contact.
# Configurer un service d'envoi (ex: Resend, Nodemailer, Brevo) dans
# app/(main)/contact/actions.ts, puis décommenter cette variable.
#
# CONTACT_EMAIL=contact@timeless-cars.fr

# ── Legacy proxy URL (alternative to the native AS24 integration) ─────────────
#
# If you have your own scraping / proxy server that returns the AS24Response
# JSON shape, set this instead of the AS24 credentials above.
# The AS24 native integration takes priority when AS24_CLIENT_ID is set.
#
# CARS_API_URL=https://your-proxy.example.com/api/cars
